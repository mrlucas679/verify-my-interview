{
  "name": "verify-my-interview",
  "version": "0.1.0",
  "description": "AI fraud investigation agent for job interview scams using Microsoft Foundry",
  "main": "dist/src/backend/server.js",
  "bin": {
    "vmi": "dist/src/backend/cli/vmi.js",
    "vmi-mcp": "dist/src/backend/mcp/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/backend/server.ts",
    "dev:web": "npm --prefix frontend run dev",
    "build": "npm run build:backend && npm run build:web",
    "build:backend": "tsc",
    "build:web": "npm --prefix frontend install && npm --prefix frontend run build",
    "start": "node dist/src/backend/server.js",
    "seed:network": "tsx src/backend/scripts/seedNetwork.ts",
    "cli": "tsx src/backend/cli/vmi.ts",
    "mcp": "tsx src/backend/mcp/server.ts",
    "azure:doctor": "tsx src/backend/scripts/azureDoctor.ts",
    "online:smoke": "tsx src/backend/scripts/onlineSmoke.ts",
    "eval": "tsx src/backend/scripts/runEvals.ts",
    "stress:agents": "tsx src/backend/scripts/stressAgents.ts",
    "verify:product": "npm run build && npm run lint && npm --prefix frontend run typecheck && npm test && npm run eval && npm run stress:agents && npm audit --omit=dev && npm --prefix frontend audit --omit=dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "fraud-detection",
    "job-scams",
    "ai-investigation",
    "microsoft-foundry"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/ai-agents": "^1.1.0",
    "@azure/ai-form-recognizer": "^5.1.0",
    "@azure/identity": "^4.5.0",
    "@azure/monitor-opentelemetry": "^1.18.1",
    "@azure/search-documents": "^12.2.0",
    "@azure/service-bus": "^7.9.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "mongodb": "^7.3.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
