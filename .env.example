# ── Microsoft Foundry (Azure AI Foundry) Agent Service ─────────────────────────
# Auth is via Microsoft Entra ID (DefaultAzureCredential), NOT an API key.
# Sign in locally with `az login`, or use a managed identity in production.
# Leave AZURE_AI_PROJECT_ENDPOINT blank to run the deterministic fallback engine
# (no Azure subscription required — the full pipeline still works).
#
# Endpoint format: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
# Optional: reuse a pre-created agent instead of an ephemeral per-case agent
# AZURE_AI_AGENT_ID=
# Optional: cap each Foundry specialist turn before deterministic fallback.
VMI_FOUNDRY_TURN_TIMEOUT_MS=10000
# Detective chat uses Foundry whenever AZURE_AI_PROJECT_ENDPOINT is set (matches
# the architecture: the detective is a Foundry agent). Set this to 0 to force the
# deterministic responder — e.g. to cap chat cost/latency — without disabling
# Foundry for the analysis pipeline. Blank/unset = Foundry chat when configured.
VMI_CHAT_FOUNDRY_ENABLED=

# ── Azure AI Search (scam-intelligence network) ────────────────────────────────
# Powers semantic matching over the report corpus. When blank, the entity graph
# builds from seed data in-memory and structural matching still works.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX=scam-reports-v2
# Foundry IQ knowledge base (agentic retrieval) for grounding the Report agent in
# prior reported scams. Unset ⇒ grounding is skipped (deterministic citations remain).
# AZURE_SEARCH_KNOWLEDGE_BASE=vmi-scam-kb

# ── Azure OpenAI (embeddings for vector search) ────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-06-01

# ── Azure AI Document Intelligence (OCR for screenshots / PDFs) ────────────────
AZURE_DOCINT_ENDPOINT=
AZURE_DOCINT_KEY=
# Optional: cap OCR polling so uploads fail clearly instead of hanging.
VMI_OCR_TIMEOUT_MS=60000

# ── Azure AI Speech (Voice Investigation — "Tell Us What Happened") ────────────
# Region short name (e.g. eastus) + key from the Speech resource. Blank ⇒ the
# /transcribe endpoint returns 503 and the UI hides the voice tab.
AZURE_SPEECH_REGION=
AZURE_SPEECH_KEY=
# AZURE_SPEECH_LOCALES=en-ZA,en-US,en-GB

# ── Azure Monitor / Application Insights (production observability) ────────────
# When set, backend traces and content-free investigation attributes are exported
# through Azure Monitor OpenTelemetry. Leave blank for offline deterministic runs.
APPLICATIONINSIGHTS_CONNECTION_STRING=
# VMI_TELEMETRY_DISABLED=1

# ── Web / OSINT research (Research agent) ──────────────────────────────────────
# Any one of these enables the research tool; they combine when multiple are set.
SERPAPI_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# ── External verification (real OSINT enrichment; each degrades gracefully) ────
# Domain WHOIS/RDAP via who-dat.as93.net (free, no key). Set to 1 to enable the
# real-WHOIS path; leave blank for the pure-offline deterministic pipeline.
WHOIS_LOOKUP_ENABLED=
WHOISJSON_API_KEY=
DOMSCAN_API_KEY=
# Abstract API suite — each product has its OWN key (https://app.abstractapi.com).
ABSTRACT_EMAIL_REPUTATION_KEY=
ABSTRACT_PHONE_KEY=
ABSTRACT_COMPANY_KEY=
ABSTRACT_IP_KEY=

# ── Optional verification APIs (legacy services degrade gracefully) ────────────
OPENCORPORATES_API_KEY=
WHOIS_XML_API_KEY=
ABSTRACT_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# Set to 1 behind Azure Container Apps/App Service ingress so Express trusts the
# first proxy hop for rate-limit client IP detection. REQUIRED in production (the
# server refuses to boot without it unless ALLOW_INSECURE=1) — see config/security.ts.
TRUST_PROXY=
# Escape hatch: set to 1 to start in production DESPITE a security-config violation
# (missing TRUST_PROXY/auth/Cosmos/anon-salt). Downgrades the boot failure to loud
# warnings. Leave UNSET in normal production — it exists for emergencies only.
ALLOW_INSECURE=
# Optional API key required by POST /report when set in production.
VMI_REPORT_API_KEY=

# ── Data layer (Cosmos DB / MongoDB API) ──────────────────────────────────────
# Powers shareable report results, the durable report corpus, and (with auth
# below) user accounts + case history. Unset ⇒ all of it is off and the app
# behaves exactly as before (graceful degradation). Stores only redacted data,
# never raw evidence text. Offline evals scrub every COSMOS_* var.
COSMOS_CONNECTION_STRING=
COSMOS_DB=vmi
# Shared-report retention (TTL index), in days. Default 30.
COSMOS_SHARE_TTL_DAYS=30
# Consented case/evidence retention (POPIA), in days. Default 365 (12 months).
COSMOS_CASE_RETENTION_DAYS=365
# OPTIONAL PII-residency split: a SECOND Cosmos account (e.g. South Africa North)
# that holds the PII stores (users, cases, usage). Unset ⇒ they share the main
# account above. The non-PII corpus (reports, shared reports) always uses the main.
COSMOS_PII_CONNECTION_STRING=

# ── Accounts & free tier (Microsoft Entra External ID — Google/Apple sign-in) ──
# The API validates the bearer JWT against Entra External ID; Google and Apple are
# configured as social IdPs inside Entra (one trusted issuer). Unset ⇒ the API is
# fully open + stateless (no accounts, no metering) exactly as today. Offline evals
# scrub all AUTH_* vars.
# Issuer = your Entra External ID tenant authority, e.g.
#   https://<tenant>.ciamlogin.com/<tenantId>/v2.0
AUTH_ISSUER=
# Audience = the API's application (client) id that tokens are issued for.
AUTH_AUDIENCE=
# Optional JWKS override (defaults to <issuer>/discovery/v2.0/keys).
AUTH_JWKS_URI=
# Free-tier policy: signed-in users are UNLIMITED for now (usage is metered, not
# capped). Anonymous visitors get this many trial checks before sign-in is required.
AUTH_ANON_TRIAL_MAX=1
# How long a hashed anonymous visitor is remembered (trial window), in days.
AUTH_ANON_TRIAL_DAYS=30
# Stable salt for hashing anonymous IPs (set in prod so trials survive restarts).
AUTH_ANON_SALT=
# Administrator allow-list (comma-separated emails). A signed-in user whose VERIFIED
# token email is on this list may perform admin actions (e.g. DELETE /reports/:id).
# Fixed + explicit — no Entra role wiring needed. Empty ⇒ no admins (fails closed).
AUTH_ADMIN_EMAILS=

# ── Evidence storage (Azure Blob — consented files only) ──────────────────────
# Stores the original evidence file for a signed-in, consented user in a PRIVATE
# container. Unset ⇒ the analyze/upload flow stays ephemeral (in memory → discard).
# Auth: set AZURE_STORAGE_ACCOUNT to use managed identity (DefaultAzureCredential),
# OR AZURE_STORAGE_CONNECTION_STRING for local/dev. POPIA retention = a Blob
# lifecycle rule on the container (infra). Offline evals scrub both.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONNECTION_STRING=

# ── Event backbone (Azure Service Bus) ────────────────────────────────────────
# Decouples report.created → reindex/recompute/notify into an async consumer
# (in-process, or a dedicated Functions consumer). Unset ⇒ everything runs
# synchronously (no-op). Topic + subscription model.
SERVICEBUS_CONNECTION_STRING=
SERVICEBUS_QUEUE=vmi-events

# ── Link unwrapping ───────────────────────────────────────────────────────────
# Set to 1 to resolve bit.ly/tinyurl "apply here" links to their real destination
# before the domain checks. Makes a network call, so leave blank for offline runs.
URL_UNWRAP_ENABLED=
