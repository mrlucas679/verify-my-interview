# Database
MONGODB_URI=mongodb://localhost:27017/verify-interview
REDIS_URL=redis://localhost:6379

# External APIs
OPENCORPORATES_API_KEY=your-opencorporates-key
WHOIS_XML_API_KEY=your-whois-xml-key
ABSTRACT_API_KEY=your-abstract-api-key

# Microsoft Foundry (Azure AI Foundry) Agent Service
# Auth is via Microsoft Entra ID (DefaultAzureCredential), NOT an API key.
# Sign in locally with `az login`, or use a managed identity in production.
# Leave AZURE_AI_PROJECT_ENDPOINT blank to run the deterministic fallback engine
# (no Azure subscription required).
#
# Endpoint format: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
# Optional: reuse a pre-created agent instead of an ephemeral per-case agent
# AZURE_AI_AGENT_ID=

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
