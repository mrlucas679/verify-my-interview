# ── Microsoft Foundry (Azure AI Foundry) Agent Service ─────────────────────────
# Auth is via Microsoft Entra ID (DefaultAzureCredential), NOT an API key.
# Sign in locally with `az login`, or use a managed identity in production.
# Leave AZURE_AI_PROJECT_ENDPOINT blank to run the deterministic fallback engine
# (no Azure subscription required — the full pipeline still works).
#
# Endpoint format: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o
# Optional: reuse a pre-created agent instead of an ephemeral per-case agent
# AZURE_AI_AGENT_ID=

# ── Azure AI Search (scam-intelligence network) ────────────────────────────────
# Powers semantic matching over the report corpus. When blank, the entity graph
# builds from seed data in-memory and structural matching still works.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX=scam-reports-v2

# ── Azure OpenAI (embeddings for vector search) ────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-06-01

# ── Azure AI Document Intelligence (OCR for screenshots / PDFs) ────────────────
AZURE_DOCINT_ENDPOINT=
AZURE_DOCINT_KEY=

# ── Web / OSINT research (Research agent) ──────────────────────────────────────
# Any one of these enables the research tool; they combine when multiple are set.
SERPAPI_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# ── External verification (real OSINT enrichment; each degrades gracefully) ────
# Domain WHOIS/RDAP via who-dat.as93.net (free, no key). Set to 1 to enable the
# real-WHOIS path; leave blank for the pure-offline deterministic pipeline.
WHOIS_LOOKUP_ENABLED=
WHOISJSON_API_KEY=
DOMSCAN_API_KEY=
# Abstract API suite — each product has its OWN key (https://app.abstractapi.com).
ABSTRACT_EMAIL_REPUTATION_KEY=
ABSTRACT_PHONE_KEY=
ABSTRACT_COMPANY_KEY=
ABSTRACT_IP_KEY=

# ── Optional verification APIs (legacy services degrade gracefully) ────────────
OPENCORPORATES_API_KEY=
WHOIS_XML_API_KEY=
ABSTRACT_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
